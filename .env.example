# =========================================================================
# CodeSight Environment Variables
# =========================================================================

# Required: OpenRouter API Key for LLM analyses
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Required: GitHub Personal Access Token (for fetching repo code and structure)
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-github-token-here

# Optional: Site URL (for SEO and sharing links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Promotional Banner Configuration
NEXT_PUBLIC_PROMO_MESSAGE=Proudly built by Suryanshu Nabheet — CodeSight repository analysis.
NEXT_PUBLIC_PROMO_LINK=https://github.com/Suryanshu-Nabheet/CodeSight
NEXT_PUBLIC_PROMO_ENABLED=false